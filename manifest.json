{
  "manifest_version": 3,
  "name": "YouTube MP3 Scraper",
  "author": "Nicolas BOGALHEIRO",
  "version": "1.0.0",
  "description": "Scrap YouTube video links (https://www.youtube.com/watch?v=X) and download MP3 audio",
  "permissions": ["activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
	"default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}