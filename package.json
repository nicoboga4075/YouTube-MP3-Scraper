{
  "name": "yt-dlp",
  "version": "1.0.0",
  "author": "Nicolas BOGALHEIRO",
  "license": "ISC",
  "ytdlpVersion": "2026.03.17",
  "dependencies": {
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "terser": "^5.39.0"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "echo \"No tests defined\"",
    "uglify:js": "powershell -Command \"Get-ChildItem *.js | ForEach-Object { terser $_.Name --compress --mangle --output ('dist\\' + $_.Name) }\"",
    "build": "npm run clean && npm run uglify:js"
  }
}
